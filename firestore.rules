rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'manzar52505@gmail.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.userId == request.auth.uid 
        && data.email is string 
        && data.email.size() <= 200
        && (!('points' in data) || (data.points is number && data.points >= 0))
        && (!('totalOrders' in data) || (data.totalOrders is number && data.totalOrders >= 0));
    }

    function isValidOrder(data) {
      return data.userId == request.auth.uid
        && data.items is list
        && data.items.size() > 0
        && data.total is number
        && data.total >= 0
        && data.status in ['pending', 'preparing', 'ready', 'delivered', 'cancelled'];
    }

    // --- Matches ---

    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().createdAt == request.time
        && incoming().points == 100; // Welcome points enforcement
      
      allow update: if (isOwner(userId) || isAdmin())
        && isValidUser(incoming())
        && (
          (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt', 'cart'])) ||
          (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['points', 'totalOrders', 'updatedAt']))
        )
        && incoming().updatedAt == request.time;
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() // Relaxed from isVerified for debugging
        && isValidOrder(incoming())
        && incoming().status == 'pending'
        && incoming().createdAt == request.time
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));

      allow update: if (isSignedIn() && existing().userId == request.auth.uid || isAdmin())
        && isValidOrder(incoming())
        && (
          // Action: Cancel Order (User)
          (existing().status == 'pending' && incoming().status == 'cancelled' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
          // Action: Update Status (Admin)
          (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
        )
        && incoming().updatedAt == request.time;
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
